rules_version = '2';

/**
 * Strict production Firestore Security Rules for Trifluenz.
 * Deploy with: `firebase deploy --only firestore:rules`
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles Collection: Any logged-in user can read profiles (discovery), but users can only write/edit their own profile
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);
    }

    // UserData Collection: Contains user-scoped campaigns, wallet, escrow, and transactions. Highly confidential; strictly owner-access only.
    match /userData/{userId} {
      allow read, write: if isOwner(userId);
    }

    // MarketplaceListings Collection: Open campaign briefs published by brands. Visible to all logged-in creators and brands.
    // Can only be created, modified, or deleted by the brand that owns the listing.
    match /marketplaceListings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.brandId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.brandId == request.auth.uid;
    }
  }
}
