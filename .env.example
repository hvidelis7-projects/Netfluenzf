# Copy to `.env` locally. Vite exposes only variables prefixed with VITE_.

# --- Firebase (optional locally — Trifluenz project defaults are embedded in src/lib/firebaseConfig.ts) ---
# Override for a different Firebase project, or set all vars in production (e.g. Vercel).
# From Firebase Console → Project settings → Your apps → Web app config
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=netfluenz-779d1.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=netfluenz-779d1
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=netfluenz-779d1.firebasestorage.app

# Optional (dev): Firestore emulator host:port when running `firebase emulators:start`
# VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Cloudinary (optional; avatars & assets — client uses unsigned upload preset, not Firebase Storage) ---
# Dashboard → Settings → Upload → Upload presets → preset must allow unsigned uploads for browser use
VITE_CLOUDINARY_CLOUD_NAME=dszmpid6y
VITE_CLOUDINARY_UPLOAD_PRESET=ml_default

# Public site URL for Open Graph / canonical (replace in index.html when deploying)
VITE_APP_ORIGIN=https://trifluenz.example

# Optional: Sentry browser DSN for client error reporting
# VITE_SENTRY_DSN=

# Set to 1 to force AI analysis errors in the marketplace (testing)
# VITE_SIMULATE_AI_FAILURE=1

# --- Gemini (optional; bundled into client via Vite `define` — use a backend proxy in production) ---
# GEMINI_API_KEY=

# --- Deploy checklist (hosting e.g. Vercel + Firebase project) ---
# 1. Set all VITE_* variables above in the host dashboard; redeploy.
# 2. Firebase Console → Authentication → Settings → Authorized domains → add your production domain.
# 3. From repo root: firebase deploy --only firestore (rules + indexes in firebase/).
# 4. Cloudinary preset must stay "Unsigned" for browser uploads; optional upload folder restrictions in preset.
